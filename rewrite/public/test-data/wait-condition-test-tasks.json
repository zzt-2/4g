            "config": {
              "conditions": [
                { "frameId": "wt-status", "fieldId": "wt-power", "operator": "lt", "threshold": 50 }
              ],
              "timeoutMs": 5000,
              "onTimeout": "fail"
            }
          },
          {
            "id": "wt-gt-lt-after",
            "kind": "delay",
            "name": "两个 wait 都通过",
            "config": { "durationMs": 10 }
          }
