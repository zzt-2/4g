{
  "version": 1,
  "templates": [
    {
      "templateId": "wt-eq",
      "name": "[等待条件] eq 数值相等",
      "tags": ["wait-condition-test", "operator-eq"],
      "definition": {
        "id": "wt-eq",
        "name": "[等待条件] eq 数值相等",
        "schedule": { "kind": "immediate" },
        "steps": [
          {
            "id": "wt-eq-wait",
            "kind": "wait-condition",
            "name": "等功率==100",
            "config": {
              "conditions": [
                { "frameId": "wt-status", "fieldId": "wt-power", "operator": "eq", "threshold": 100 }
              ],
              "timeoutMs": 5000,
              "onTimeout": "fail"
            }
          },
          {
            "id": "wt-eq-after",
            "kind": "delay",
            "name": "匹配后推进到这里",
            "config": { "durationMs": 10 }
          }
        ],
        "errorPolicy": { "onFailure": "stop" }
      },
      "createdAt": "2026-06-24T00:00:00.000Z",
      "updatedAt": "2026-06-24T00:00:00.000Z"
    },
