{
  "schemaVersion": 1,
  "selectedFrameId": "wt-status",
  "frames": [
    {
      "id": "wt-status",
      "name": "[等待条件测试] 状态遥测帧",
      "direction": "receive",
      "description": "S014 等待条件测试专用。本帧覆盖：① 功率值 wt-power(uint16 数值) → 测 eq/gt/lt/gte/lte 数值比较路径 ② 原始状态字 wt-raw-status(uint32, 值如 0x0001) → threshold 写 0x0001 测 toNumber 的 0x 前缀解析 ③ 状态串 wt-status-text(string 枚举, OK/ERROR/STANDBY) → 测 contains(子串) 与字符串字典序比较 ④ 可选遥测 wt-optional-payload(可选 uint16) → 该字段缺失时 fieldValues 里是 null, 测 null → false 路径(除 any 外全部返回 false)。",
      "fields": [
        {
          "id": "sync",
          "name": "帧头",
          "dataType": "uint32",
          "length": 4,
          "defaultValue": "0x1ACFFC1D",
          "inputType": "input",
          "configurable": false,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "wt-power",
          "name": "功率值",
          "dataType": "uint16",
          "length": 2,
          "description": "数值字段, 用来测 eq/gt/lt/gte/lte 的数值比较。建议发 100(=threshold) / 150(>threshold) / 50(<threshold) 三档验证。",
          "defaultValue": "0",
          "inputType": "input",
          "configurable": true,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "wt-raw-status",
          "name": "原始状态字",
          "dataType": "uint32",
          "length": 4,
          "description": "整数值字段, 实际值用十六进制(如 0x0001)。threshold 写成 0x0001, 测 toNumber 的 0x 前缀解析后走数值比较。也用来测 eq 1(十进制 threshold) vs eq 0x0001(十六进制 threshold) 是否等价。",
          "defaultValue": "0x00000000",
          "inputType": "input",
          "configurable": true,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "wt-status-text",
          "name": "状态串",
          "dataType": "uint32",
          "length": 4,
          "description": "枚举状态字段。真实业务用数值编码, 但 condition 求值时 fieldValues 可能是解码后的字符串(由 bridge 上游决定)。这里用 string threshold 测 contains(子串 OK) 与字符串字典序比较(actual='OK' threshold='NO' 等实际行为)。注释: dataType 是帧定义侧的存储类型, 求值侧 fieldValues 是已解码标量。",
          "defaultValue": "0",
          "inputType": "select",
          "configurable": true,
          "options": [
            { "value": "0", "label": "STANDBY" },
            { "value": "1", "label": "OK" },
            { "value": "2", "label": "ERROR" }
          ],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "wt-optional-payload",
          "name": "可选遥测",
          "dataType": "uint16",
          "length": 2,
          "description": "可选字段。某些帧该字段不出现 → fieldValues 里是 null/undefined → 测 null → false 路径: 除 any 外所有 operator 都返回 false, any 字段无值也返回 false。发帧时可通过省略该字段模拟缺失。",
          "defaultValue": "0",
          "inputType": "input",
          "configurable": true,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "checksum",
          "name": "checksum",
          "dataType": "uint32",
          "length": 4,
          "defaultValue": "0x00000000",
          "inputType": "input",
          "configurable": false,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": true, "startFieldIndex": 0, "endFieldIndex": 4, "checksumMethod": "sum32" },
          "bigEndian": true
        }
      ],
      "frameType": "wt-test",
      "protocol": "rs422-fixed",
      "options": { "autoChecksum": true, "bigEndian": true, "includeLengthField": false },
      "identifierRules": [
        { "startIndex": 0, "endIndex": 3, "operator": "eq", "value": "0x1ACFFC1D", "logicOperator": "and" }
      ]
    },
    {
      "id": "wt-aux",
      "name": "[等待条件测试] 辅助帧",
      "direction": "receive",
      "description": "S014 第二个 receive 帧, 用来测 frameId 索引隔离：条件等 wt-status 的字段时, 发来 wt-aux 的帧(即使字段 id 同名)不该触发匹配。也作为 OR 组合里跨帧条件的一方。",
      "fields": [
        {
          "id": "sync",
          "name": "帧头",
          "dataType": "uint32",
          "length": 4,
          "defaultValue": "0x1ACFFC1D",
          "inputType": "input",
          "configurable": false,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "wt-aux-val",
          "name": "辅助值",
          "dataType": "uint16",
          "length": 2,
          "description": "辅助数值字段。注意 id 与 wt-status 的字段故意不同, 避免同名混淆。",
          "defaultValue": "0",
          "inputType": "input",
          "configurable": true,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "wt-aux-flag",
          "name": "辅助标志",
          "dataType": "uint8",
          "length": 1,
          "description": "布尔型标志(0/1)。OR 组合测试里用作跨帧第二个条件的一方。",
          "defaultValue": "0",
          "inputType": "input",
          "configurable": true,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "checksum",
          "name": "checksum",
          "dataType": "uint32",
          "length": 4,
          "defaultValue": "0x00000000",
          "inputType": "input",
          "configurable": false,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": true, "startFieldIndex": 0, "endFieldIndex": 2, "checksumMethod": "sum32" },
          "bigEndian": true
        }
      ],
      "frameType": "wt-test",
      "protocol": "rs422-fixed",
      "options": { "autoChecksum": true, "bigEndian": true, "includeLengthField": false },
      "identifierRules": [
        { "startIndex": 0, "endIndex": 3, "operator": "eq", "value": "0x2ACFFC1D", "logicOperator": "and" }
      ]
    },
    {
      "id": "wt-counter",
      "name": "[等待条件测试] 计数器帧",
      "direction": "receive",
      "description": "S014 第三个 receive 帧, 用来测 ① change operator(threshold=上次值语义, 实际值变化时匹配) ② any operator(只看字段有无值, 不看 threshold) ③ sourceId 过滤(只匹配指定来源的帧)。重复发送可观察 change 的递增触发。",
      "fields": [
        {
          "id": "sync",
          "name": "帧头",
          "dataType": "uint32",
          "length": 4,
          "defaultValue": "0x1ACFFC1D",
          "inputType": "input",
          "configurable": false,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "wt-count",
          "name": "计数值",
          "dataType": "uint32",
          "length": 4,
          "description": "递增计数器。change operator 测试: threshold 设为 0, 第一帧 actual=1 (≠0 且非空) → 匹配; 若 actual=0 → 不匹配。any operator: 只要有值就匹配。",
          "defaultValue": "0",
          "inputType": "input",
          "configurable": true,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": false, "startFieldIndex": 0, "endFieldIndex": 0, "checksumMethod": "sum8" },
          "bigEndian": true
        },
        {
          "id": "checksum",
          "name": "checksum",
          "dataType": "uint32",
          "length": 4,
          "defaultValue": "0x00000000",
          "inputType": "input",
          "configurable": false,
          "options": [],
          "dataParticipationType": "direct",
          "validOption": { "isChecksum": true, "startFieldIndex": 0, "endFieldIndex": 1, "checksumMethod": "sum32" },
          "bigEndian": true
        }
      ],
      "frameType": "wt-test",
      "protocol": "rs422-fixed",
      "options": { "autoChecksum": true, "bigEndian": true, "includeLengthField": false },
      "identifierRules": [
        { "startIndex": 0, "endIndex": 3, "operator": "eq", "value": "0x3ACFFC1D", "logicOperator": "and" }
      ]
    }
  ]
}
